# Environment variables for local development and testing
# Copy this file to .env and fill in your actual values
# .env is git-ignored and will not be committed

# =============================================================================
# OpenAPI Verification Tests (tests/verification/)
# =============================================================================

# Primary: Polarion deployed extensions (recommended for production verification)
POLARION_URL=https://polarion.example.com
POLARION_TOKEN=your-polarion-bearer-token-here

# Fallback: GitHub source code repositories (for local development)
# Option A: Use 'gh auth login' (token auto-detected via 'gh auth token')
# Option B: Set GITHUB_TOKEN manually
GITHUB_TOKEN=your-github-personal-access-token-here

# Parameter validation (default: true)
# Set to false to only validate method names (skip parameter checking)
VALIDATE_PARAMETERS=true

# =============================================================================
# Usage:
# =============================================================================
#
# 1. Copy this file:
#    cp .env.example .env
#
# 2. Edit .env and add your actual tokens
#
# 3. Load environment variables:
#    # Bash/Zsh:
#    set -a; source .env; set +a
#
#    # Fish:
#    export (cat .env | grep -v '^#' | xargs)
#
# 4. Run verification tests:
#    uv run tox -e verify-openapi-mapping
#
# =============================================================================
# Security Notes:
# =============================================================================
# - NEVER commit .env file (it's in .gitignore)
# - NEVER commit actual tokens to this .env.example file
# - Rotate tokens regularly
# - Use tokens with minimal required permissions
